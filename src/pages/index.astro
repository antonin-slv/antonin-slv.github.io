<script is:inline>
  const savedLang = localStorage.getItem('user-pref-lang');
  const browserLang = navigator.language.startsWith('fr') ? 'fr' : 'en';
  
  // Priorité : 1. Choix sauvegardé | 2. Langue navigateur | 3. Défaut (en)
  console.log('Langue sauvée :', savedLang);
  const targetLang = savedLang || browserLang

  window.location.pathname = `/${targetLang}/`;
</script> 
